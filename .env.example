# ============================================================
# Terra Rex Energy — WhatsApp AI Agent Platform — .env.example
# ============================================================
# Copy this file to `.env` at the repo root and fill values.
# The backend reads from this file via `pydantic-settings`.
# The frontend reads only vars prefixed with `NEXT_PUBLIC_`.

# ------------------------------------------------------------
# App / auth / infra
# ------------------------------------------------------------
APP_ENV=local                          # local | staging | production       [MANDATORY]
APP_PORT=8000                          # backend port                        [optional]
APP_SECRET_KEY=change-me-to-64-hex     # JWT + cookie signing                [MANDATORY]
JWT_ACCESS_TTL_MIN=120                 # access token lifetime (minutes)     [optional]
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR      [optional]
CORS_ORIGINS=http://localhost:3000     # comma-separated                     [MANDATORY]
# Outbound kill-switch. When true, every AiSensy outbound call (AI reply,
# manual reply, campaign) is refused with a logged ProviderPermanentError.
# Webhooks, dashboard, DB, and inbound processing keep working. Flip back to
# false and redeploy to resume sending. Default: false.
DISABLE_SERVICE=false

# ------------------------------------------------------------
# Database / Redis
# ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://terrarex:terrarex@localhost:5432/terrarex   # [MANDATORY]
REDIS_URL=redis://localhost:6379/0                                            # [MANDATORY]
RQ_QUEUE_NAME=whatsapp-agent           # name of RQ queue                     [optional]

# ------------------------------------------------------------
# AiSensy (BSP) — values provided by AiSensy dashboard
# AiSensy ships two separate APIs with different credentials:
#   * Campaign API     — backend.aisensy.com/campaign/t1/api/v2, `apiKey` in body
#   * Project API v1   — apis.aisensy.com/project-apis/v1/project/{project_id}/messages, header auth
#     (older accounts: Direct APIs at backend.aisensy.com/direct-apis/t1/messages)
# Campaign and session/AI replies use different API keys. Put the CAMPAIGN key in
# AISENSY_API_KEY and the PROJECT API key in AISENSY_API_TOKEN.
# Dashboard tabs to copy from: "API Campaign Key" and "Project API Keys".
# ------------------------------------------------------------
AISENSY_API_KEY=aisensy-api-key-here                      # [MANDATORY — "API Campaign Key" tab, used in body]
# Token/password for session sends (AI replies + human replies from the inbox).
# Copy from the "Project API Keys" tab in AiSensy. Leave empty only if your AiSensy
# account uses a single unified credential for both campaign and session.
AISENSY_API_TOKEN=
# Project id shown on the "Project API Keys" tab — REQUIRED when AISENSY_SESSION_ENDPOINT
# contains `{project_id}` (i.e. Project API v1). Not needed on legacy Direct APIs.
AISENSY_PROJECT_ID=
# Auth style used against the session endpoint:
#   auto         — try Authorization: Bearer first, then X-AiSensy-Project-API-Pwd on 401/422 (default)
#   bearer       — only Authorization: Bearer <token>
#   project_pwd  — only X-AiSensy-Project-API-Pwd: <token>  (legacy projects)
# Use POST /api/v1/integrations/aisensy/probe-auth to detect which style your account accepts,
# then pin it here to avoid the probe on every send.
AISENSY_AUTH_METHOD=auto
# Base URL. Project API v1 -> https://apis.aisensy.com. Legacy Direct APIs -> https://backend.aisensy.com.
AISENSY_BASE_URL=https://apis.aisensy.com
AISENSY_CAMPAIGN_ENDPOINT=/campaign/t1/api/v2             # [optional — from AiSensy; hosted on backend.aisensy.com]
# Project API v1 path. `{project_id}` is interpolated from AISENSY_PROJECT_ID at request time.
# For legacy Direct APIs, change to: /direct-apis/t1/messages  (and set AISENSY_BASE_URL=https://backend.aisensy.com).
AISENSY_SESSION_ENDPOINT=/project-apis/v1/project/{project_id}/messages
# Same value must be configured in the AiSensy webhook URL settings. If inbound webhooks return 401,
# leave this empty temporarily to disable verification, or fix the secret / signature header in AiSensy.
AISENSY_WEBHOOK_SECRET=
AISENSY_SOURCE=terrarex-dashboard                         # [optional]

# ------------------------------------------------------------
# AI provider
# ------------------------------------------------------------
AI_PROVIDER=anthropic                  # anthropic | openai                  [MANDATORY]
ANTHROPIC_API_KEY=sk-ant-...           # required if AI_PROVIDER=anthropic   [conditional]
OPENAI_API_KEY=sk-...                  # required if AI_PROVIDER=openai OR embeddings via openai [conditional]
AI_MODEL=claude-sonnet-4-6             # LLM model id                        [optional]

AI_EMBEDDING_PROVIDER=openai           # openai (default)                    [optional]
AI_EMBEDDING_MODEL=text-embedding-3-small                                    # [optional]
AI_EMBEDDING_DIMENSIONS=1536           # must match model                    [optional]

# ------------------------------------------------------------
# Business policy
# ------------------------------------------------------------
SERVICE_WINDOW_HOURS=24                # WhatsApp free-form reply window     [optional]
CAMPAIGN_ATTRIBUTION_HOURS=72          # window for attributing replies      [optional]
BUSINESS_NAME=Terra Rex Energy                                               # [optional]
BUSINESS_TIMEZONE=Asia/Kolkata                                               # [optional]

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1                        # [MANDATORY]
NEXT_PUBLIC_APP_NAME=Terra Rex WhatsApp                                      # [optional]
