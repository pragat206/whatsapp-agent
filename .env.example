# ============================================================
# Terra Rex Energy — WhatsApp AI Agent Platform — .env.example
# ============================================================
# Copy this file to `.env` at the repo root and fill values.
# The backend reads from this file via `pydantic-settings`.
# The frontend reads only vars prefixed with `NEXT_PUBLIC_`.

# ------------------------------------------------------------
# App / auth / infra
# ------------------------------------------------------------
APP_ENV=local                          # local | staging | production       [MANDATORY]
APP_PORT=8000                          # backend port                        [optional]
APP_SECRET_KEY=change-me-to-64-hex     # JWT + cookie signing                [MANDATORY]
JWT_ACCESS_TTL_MIN=120                 # access token lifetime (minutes)     [optional]
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR      [optional]
CORS_ORIGINS=http://localhost:3000     # comma-separated                     [MANDATORY]

# ------------------------------------------------------------
# Database / Redis
# ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://terrarex:terrarex@localhost:5432/terrarex   # [MANDATORY]
REDIS_URL=redis://localhost:6379/0                                            # [MANDATORY]
RQ_QUEUE_NAME=whatsapp-agent           # name of RQ queue                     [optional]

# ------------------------------------------------------------
# AiSensy (BSP) — values provided by AiSensy dashboard
# ------------------------------------------------------------
AISENSY_API_KEY=aisensy-api-key-here                      # [MANDATORY — from AiSensy]
AISENSY_BASE_URL=https://backend.aisensy.com              # [optional — from AiSensy if custom]
AISENSY_CAMPAIGN_ENDPOINT=/campaign/t1/api/v2             # [optional — from AiSensy]
AISENSY_SESSION_ENDPOINT=/direct-apis/t1/messages         # [optional — from AiSensy]
AISENSY_WEBHOOK_SECRET=set-in-aisensy-webhook-settings    # [MANDATORY — you choose & paste in AiSensy]
AISENSY_SOURCE=terrarex-dashboard                         # [optional]

# ------------------------------------------------------------
# AI provider
# ------------------------------------------------------------
AI_PROVIDER=anthropic                  # anthropic | openai                  [MANDATORY]
ANTHROPIC_API_KEY=sk-ant-...           # required if AI_PROVIDER=anthropic   [conditional]
OPENAI_API_KEY=sk-...                  # required if AI_PROVIDER=openai OR embeddings via openai [conditional]
AI_MODEL=claude-sonnet-4-6             # LLM model id                        [optional]

AI_EMBEDDING_PROVIDER=openai           # openai (default)                    [optional]
AI_EMBEDDING_MODEL=text-embedding-3-small                                    # [optional]
AI_EMBEDDING_DIMENSIONS=1536           # must match model                    [optional]

# ------------------------------------------------------------
# Business policy
# ------------------------------------------------------------
SERVICE_WINDOW_HOURS=24                # WhatsApp free-form reply window     [optional]
CAMPAIGN_ATTRIBUTION_HOURS=72          # window for attributing replies      [optional]
BUSINESS_NAME=Terra Rex Energy                                               # [optional]
BUSINESS_TIMEZONE=Asia/Kolkata                                               # [optional]

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1                        # [MANDATORY]
NEXT_PUBLIC_APP_NAME=Terra Rex WhatsApp                                      # [optional]
